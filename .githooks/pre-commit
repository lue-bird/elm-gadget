printf "Running pre-commit hooks\n\n"

printf "  1. Running elm-format... "

if elm-format . --yes > /dev/null 2>&1; then
    printf "Success!\n\n"
else 
    printf "Failed!\n\n"
    exit 1
fi

printf "  2. Generating docs.json... "

if elm make --docs=docs.json > /dev/null 2>&1; then
    printf "Success!\n\n"
else 
    printf "Failed!\n\n"
    exit 1
fi

printf "  3. Staging changed files\n\n"

git add .

printf "Pre-commit hooks complete\n\n"

exit 0